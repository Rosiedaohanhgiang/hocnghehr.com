<script>
        document.addEventListener('DOMContentLoaded', function () {
            // Feather Icons Initialization
            feather.replace();

            // Mobile Menu Toggle
            const mobileMenuButton = document.getElementById('mobile-menu-button');
            const mobileMenu = document.getElementById('mobile-menu');
            const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
            
            mobileMenuButton.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });

            mobileNavLinks.forEach(link => {
                link.addEventListener('click', () => {
                     mobileMenu.classList.add('hidden');
                });
            });

            // Smooth Scroll & Active Nav Link Highlighting
            // ... (Giữ nguyên các logic UI khác của bạn ở đây) ...

            // --- FORM SUBMIT LOGIC GỬI VỀ TELEGRAM (VIA GOOGLE APPS SCRIPT) ---
            const contactForm = document.getElementById('contact-form');
            if (contactForm) {
                const formMessage = document.getElementById('form-message');
                const submitButton = document.getElementById('submit-contact-form');

                contactForm.addEventListener('submit', function(event) {
                    event.preventDefault();

                    // Simple validation
                    const name = document.getElementById('name').value;
                    const email = document.getElementById('email').value;
                    const message = document.getElementById('message').value;

                    if (!name || !email || !message) {
                        formMessage.textContent = 'Vui lòng điền đầy đủ các trường thông tin bắt buộc.';
                        formMessage.className = 'text-center mb-4 p-3 rounded-lg bg-red-100 text-red-700 block';
                        return;
                    }

                    submitButton.textContent = 'Đang gửi...';
                    submitButton.disabled = true;

                    // Đường link Web App Google Apps Script bạn vừa tạo
                    const googleWebAppUrl = "https://script.google.com/macros/s/AKfycbzEDcJmjBzKMppFOzh-lbkcQ-KyDqCF3YF2A7wCPGtPrEZYTT2a6EYPszKOiHj6n7Djxg/exec";
                    
                    fetch(googleWebAppUrl, {
                        method: "POST",
                        body: new FormData(this)
                    })
                    .then(response => response.json())
                    .then(data => {
                        if(data.result === "success") {
                            formMessage.textContent = 'Cảm ơn bạn! Chúng tôi đã nhận được yêu cầu và sẽ phản hồi sớm nhất.';
                            formMessage.className = 'text-center mb-4 p-3 rounded-lg bg-green-100 text-green-700 block';
                            contactForm.reset();
                        } else {
                            throw new Error("Lỗi máy chủ");
                        }
                    })
                    .catch((err) => {
                        formMessage.textContent = 'Gửi thất bại! Vui lòng thử lại sau.';
                        formMessage.className = 'text-center mb-4 p-3 rounded-lg bg-red-100 text-red-700 block';
                    })
                    .finally(() => {
                        submitButton.textContent = 'Gửi Yêu Cầu';
                        submitButton.disabled = false;
                    });
                });
            }
        });
    </script>
